{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Task": {
      "title": "Task",
      "description": "A user task",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" }
      },
      "required": ["userId", "title"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User data"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User tasks"
    }
  }
}
